---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  keywords?: string;
}

const SITE_URL = 'https://fullpos.fulltechrd.com';
const defaultTitle = 'FullPOS Punto de Venta | Sistema POS para ventas, inventario y caja';
const defaultDescription = 'FullPOS es un sistema de punto de venta para negocios en República Dominicana. Controla ventas, inventario, caja, clientes, facturación y reportes desde Windows, con FullPOS Owner para ver datos desde el celular.';
const defaultKeywords = 'FullPOS, FullPOS punto de venta, FullPOS_Punto de ventas, punto de venta, punto de ventas, sistema POS, software POS, sistema de ventas, sistema para tienda, sistema para minimarket, sistema para ferretería, control de inventario, facturación, caja, reportes, FullPOS Owner, POS República Dominicana';
const {
  title = defaultTitle,
  description = defaultDescription,
  ogImage = '/images/hero-fullpos-devices.png',
  canonicalPath,
  keywords = defaultKeywords,
} = Astro.props;
const canonicalUrl = new URL(canonicalPath || Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = new URL(ogImage, SITE_URL).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      'name': 'FullTech SRL / APYRA',
      'url': SITE_URL,
      'logo': `${SITE_URL}/logo.png`,
      'telephone': '+1-849-429-0310',
      'areaServed': 'República Dominicana',
      'address': {
        '@type': 'PostalAddress',
        'addressLocality': 'Higüey',
        'addressRegion': 'La Altagracia',
        'addressCountry': 'DO',
      },
      'contactPoint': [
        {
          '@type': 'ContactPoint',
          'telephone': '+1-849-429-0310',
          'contactType': 'sales and customer support',
          'areaServed': 'DO',
          'availableLanguage': 'Spanish',
          'url': 'https://wa.me/18494290310',
        },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      'url': SITE_URL,
      'name': 'FullPOS Punto de Venta',
      'alternateName': ['FullPOS', 'FullPOS_Punto de ventas', 'Sistema POS FullPOS'],
      'publisher': { '@id': `${SITE_URL}/#organization` },
      'inLanguage': 'es-DO',
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE_URL}/#software`,
      'name': 'FullPOS',
      'alternateName': ['FullPOS Punto de Venta', 'FullPOS_Punto de ventas', 'Sistema POS FullPOS'],
      'applicationCategory': 'BusinessApplication',
      'applicationSubCategory': 'Point of Sale Software',
      'operatingSystem': 'Windows',
      'description': defaultDescription,
      'url': SITE_URL,
      'image': ogImageUrl,
      'publisher': { '@id': `${SITE_URL}/#organization` },
      'offers': {
        '@type': 'Offer',
        'price': '60',
        'priceCurrency': 'USD',
        'availability': 'https://schema.org/InStock',
        'description': 'Licencia mínima de 3 meses para FullPOS, con FullPOS Owner, soporte y actualizaciones.',
      },
      'featureList': [
        'Ventas y facturación',
        'Control de inventario',
        'Caja y cierres',
        'Clientes y compras',
        'Reportes del negocio',
        'FullPOS Owner para reportes desde el celular',
      ],
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      'url': canonicalUrl,
      'name': title,
      'description': description,
      'isPartOf': { '@id': `${SITE_URL}/#website` },
      'about': { '@id': `${SITE_URL}/#software` },
      'inLanguage': 'es-DO',
      'primaryImageOfPage': {
        '@type': 'ImageObject',
        'url': ogImageUrl,
      },
    },
  ],
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="FullPOS punto de venta para ventas, inventario, caja y reportes" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="FullPOS" />
    <meta property="og:locale" content="es_DO" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Theme Color -->
    <meta name="theme-color" content="#2563eb" />
    <meta name="application-name" content="FullPOS Punto de Venta" />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="FullTech SRL / APYRA" />
    <meta name="geo.region" content="DO" />
    <meta name="geo.placename" content="Higüey, La Altagracia, República Dominicana" />

    <script type="application/ld+json">
      {JSON.stringify(jsonLd)}
    </script>
  </head>
  <body>
    <slot />

    <!-- WhatsApp Floating Button -->
    <a
      href="https://wa.me/18494290310"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-green-500 text-white shadow-lg transition-all duration-300 hover:bg-green-600 hover:scale-110 hover:shadow-xl"
      aria-label="Contactar por WhatsApp"
    >
      <svg class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
    </a>

    <Footer />
    <!-- Download Handler Script -->
    <script is:inline src="/js/download-handler.js"></script>
  </body>
</html>
