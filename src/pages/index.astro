---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import BusinessTypes from '../components/BusinessTypes.astro';
import Benefits from '../components/Benefits.astro';
import WhyFullpos from '../components/WhyFullpos.astro';
import CompanyInfo from '../components/CompanyInfo.astro';
import MobileReports from '../components/MobileReports.astro';
import Screenshots from '../components/Screenshots.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="FullPOS Punto de Venta | Sistema POS para negocios en República Dominicana"
  description="FullPOS Punto de Venta es un sistema POS para tiendas, minimarkets, ferreterías y negocios. Controla ventas, inventario, caja, facturación, clientes y reportes desde Windows, con FullPOS Owner para ver datos desde el celular."
  canonicalPath="/"
>
  <Navbar />
  <main>
    <Hero />
    <BusinessTypes />
    <Benefits />
    <WhyFullpos />
    <CompanyInfo />
    <MobileReports />
    <Screenshots />
    <HowItWorks />
    <Pricing />
    <Testimonials />
    <FAQ />
    <FinalCTA />
    <Contact />
  </main>
</Layout>
