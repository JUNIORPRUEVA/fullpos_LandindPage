---
---

<section class="relative overflow-hidden pt-20 pb-14 sm:pt-32 sm:pb-20 lg:pt-40 lg:pb-28">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary/[0.03] to-transparent" />
  
  <!-- Decorative elements -->
  <div class="absolute top-20 left-10 h-72 w-72 rounded-full bg-primary/5 blur-3xl" />
  <div class="absolute bottom-20 right-10 h-96 w-96 rounded-full bg-accent/5 blur-3xl" />

  <div class="container-custom relative">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Left Content -->
      <div class="text-center lg:text-left">
        <!-- Badges -->
        <div class="mb-5 flex flex-wrap justify-center gap-1.5 lg:justify-start">
          <span class="badge text-[10px] sm:text-xs">
            <svg class="h-3 w-3 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 010 12.728m-2.829-2.829a5 5 0 000-7.07m-4.243 4.243a1 1 0 010-1.414" /></svg>
            Sin Internet
          </span>
          <span class="badge text-[10px] sm:text-xs">
            <svg class="h-3 w-3 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            Informes Móviles
          </span>
          <span class="badge text-[10px] sm:text-xs">
            <svg class="h-3 w-3 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" /></svg>
            Fácil de Usar
          </span>
          <span class="badge text-[10px] sm:text-xs">
            <svg class="h-3 w-3 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            Instalación Rápida
          </span>
        </div>

        <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl md:text-5xl lg:text-6xl leading-tight sm:leading-tight">
          El Software de Punto de Venta Completo para tu Negocio
        </h1>
        <p class="mt-4 text-base leading-relaxed text-gray-500 sm:text-lg sm:mt-6 lg:text-xl">
          Administra ventas, inventario, compras, gastos e informes desde un solo sistema potente que funciona incluso sin internet.
        </p>

        <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-start sm:mt-8">
          <a href="#demo" class="btn-primary w-full sm:w-auto px-6 py-3.5 text-sm sm:px-8 sm:py-4 sm:text-base">
            <svg class="mr-2 h-4 w-4 sm:h-5 sm:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Descargar Demo Gratis
          </a>
          <a href="#contacto" class="btn-secondary w-full sm:w-auto px-6 py-3.5 text-sm sm:px-8 sm:py-4 sm:text-base">
            Contáctanos
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-4 sm:gap-6 lg:justify-start sm:mt-8">
          <div class="flex items-center gap-1.5 text-xs text-gray-400 sm:text-sm sm:gap-2">
            <svg class="h-3.5 w-3.5 text-green-500 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Demo 5 días gratis
          </div>
          <div class="flex items-center gap-1.5 text-xs text-gray-400 sm:text-sm sm:gap-2">
            <svg class="h-3.5 w-3.5 text-green-500 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Sin compromiso
          </div>
          <div class="flex items-center gap-1.5 text-xs text-gray-400 sm:text-sm sm:gap-2">
            <svg class="h-3.5 w-3.5 text-green-500 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Soporte profesional
          </div>
        </div>
      </div>

      <!-- Right Content - Hero Image -->
      <div class="relative flex items-center justify-center">
        <div class="relative mx-auto w-full max-w-sm sm:max-w-md lg:max-w-lg">
          <img
            src="/images/imagenprincipal.png"
            alt="FullPOS - Software de Punto de Venta"
            class="w-full h-auto"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>
