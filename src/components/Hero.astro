---
const highlights = [
  { label: 'Funciona sin Internet', icon: 'signal' },
  { label: 'Reportes en tu Celular', icon: 'phone' },
  { label: 'Instalación Rápida', icon: 'bolt' },
  { label: 'Soporte 24/7', icon: 'support' },
];
---

<section class="relative isolate overflow-hidden bg-dark pt-28 pb-16 sm:pt-32 lg:pt-36 lg:pb-20">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_72%_18%,rgba(14,165,233,0.42),transparent_28%),radial-gradient(circle_at_18%_30%,rgba(37,99,235,0.34),transparent_24%),linear-gradient(135deg,#020617_0%,#06142b_48%,#020617_100%)]" />
  <div class="absolute inset-0 opacity-[0.13]" style="background-image: linear-gradient(rgba(96,165,250,0.26) 1px, transparent 1px), linear-gradient(90deg, rgba(96,165,250,0.26) 1px, transparent 1px); background-size: 46px 46px;" />
  <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-primary/20 to-transparent" />
  <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-dark via-dark/80 to-transparent" />
  <div class="absolute right-[-12rem] top-20 h-[34rem] w-[34rem] rounded-full bg-accent/25 blur-[120px]" />
  <div class="absolute left-[-12rem] bottom-[-10rem] h-[30rem] w-[30rem] rounded-full bg-primary/25 blur-[120px]" />

  <div class="container-custom relative">
    <div class="grid items-center gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:gap-4">
      <div class="relative z-10 text-center lg:text-left">
        <span class="inline-flex items-center rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-primary-light shadow-lg shadow-primary/10">
          Software POS de última generación
        </span>

        <h1 class="mt-5 text-4xl font-extrabold leading-[0.98] tracking-tight text-white sm:text-5xl lg:text-6xl">
          Full<span class="text-primary-light">POS</span>
          <span class="mt-3 block max-w-2xl text-2xl leading-tight text-white sm:text-3xl lg:text-4xl">
            El control total de tu negocio, estés donde estés.
          </span>
        </h1>

        <p class="mx-auto mt-5 max-w-xl text-sm leading-relaxed text-slate-300 sm:text-base lg:mx-0 lg:text-lg">
          Software POS completo que funciona sin internet, con reportes en tiempo real desde tu celular y todas las herramientas que tu negocio necesita.
        </p>

        <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:max-w-xl">
          {highlights.map((item) => (
            <div class="flex items-center gap-2 rounded-2xl border border-white/10 bg-white/[0.045] px-3 py-3 text-left shadow-lg shadow-black/10 backdrop-blur">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-primary/15 text-primary-light">
                {item.icon === 'signal' && (
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0" /></svg>
                )}
                {item.icon === 'phone' && (
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                )}
                {item.icon === 'bolt' && (
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                )}
                {item.icon === 'support' && (
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M5.636 5.636l3.536 3.536m0 5.656l-3.536 3.536" /></svg>
                )}
              </div>
              <span class="text-[11px] font-semibold leading-tight text-slate-100 sm:text-xs">{item.label}</span>
            </div>
          ))}
        </div>

        <div class="mt-7 flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-start">
          <button class="download-btn inline-flex w-full items-center justify-center rounded-xl bg-primary px-6 py-3.5 text-sm font-bold text-white shadow-2xl shadow-primary/30 transition-all duration-300 hover:-translate-y-1 hover:bg-primary-dark sm:w-auto" data-original-text="Descargar Demo Gratis">
            <svg class="download-icon mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            <span class="download-text">Descargar Demo Gratis</span>
          </button>
          <a href="#video" class="inline-flex w-full items-center justify-center rounded-xl border border-white/18 bg-white/[0.04] px-6 py-3.5 text-sm font-semibold text-white backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-white/35 hover:bg-white/10 sm:w-auto">
            <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
            Ver Video
          </a>
        </div>

        <p class="mt-4 text-xs text-slate-400">
          Demo completamente gratis durante 5 días. Sin tarjeta de crédito.
        </p>
      </div>

      <div class="relative min-h-[300px] sm:min-h-[410px] lg:min-h-[500px]">
        <div class="absolute inset-0 rounded-full bg-primary/20 blur-[90px]" />
        <div class="absolute left-1/2 top-1/2 h-44 w-[82%] -translate-x-1/2 translate-y-[28%] rounded-[100%] bg-primary/20 blur-3xl" />
        <img
          src="/images/hero-fullpos-devices.png"
          alt="FullPOS en laptop y FullPOS Owner en celular"
          width="1672"
          height="941"
          class="absolute left-1/2 top-1/2 w-[130%] max-w-none -translate-x-1/2 -translate-y-1/2 object-contain drop-shadow-[0_42px_70px_rgba(0,0,0,0.55)] sm:w-[120%] lg:left-[54%] lg:w-[130%]"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
