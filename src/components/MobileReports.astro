---
---

<section class="py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Left: Phone Mockup -->
      <div class="flex justify-center lg:justify-start">
        <div class="relative">
          <!-- Phone frame -->
          <div class="relative mx-auto w-56 animate-float sm:w-64 lg:w-72">
            <div class="rounded-[2rem] border-4 border-gray-800 bg-white shadow-2xl sm:rounded-[2.5rem]">
              <!-- Notch -->
              <div class="flex items-center justify-center pt-2 sm:pt-3">
                <div class="h-1.5 w-16 rounded-full bg-gray-800 sm:h-2 sm:w-20" />
              </div>
              <!-- Screen -->
              <div class="p-3 sm:p-4">
                <div class="rounded-xl bg-gradient-to-b from-primary/5 to-accent/5 p-3 sm:rounded-2xl sm:p-4">
                  <!-- Header -->
                  <div class="mb-3 flex items-center justify-between sm:mb-4">
                    <div>
                      <div class="text-[10px] font-semibold text-gray-400 sm:text-xs">FullPOS Owner</div>
                      <div class="text-xs font-bold text-gray-900 sm:text-sm">Dashboard</div>
                    </div>
                    <div class="flex gap-1">
                      <div class="h-1.5 w-1.5 rounded-full bg-green-400 sm:h-2 sm:w-2" />
                      <div class="h-1.5 w-1.5 rounded-full bg-green-400 sm:h-2 sm:w-2" />
                    </div>
                  </div>
                  <!-- Stats Cards -->
                  <div class="space-y-2 sm:space-y-3">
                    <div class="rounded-lg bg-white p-2 shadow-sm sm:rounded-xl sm:p-3">
                      <div class="flex items-center justify-between">
                        <span class="text-[10px] text-gray-400 sm:text-xs">Ventas Hoy</span>
                        <span class="text-[10px] font-bold text-green-500 sm:text-xs">+12%</span>
                      </div>
                      <div class="mt-0.5 text-sm font-bold text-gray-900 sm:mt-1 sm:text-lg">RD$ 1,284</div>
                    </div>
                    <div class="rounded-lg bg-white p-2 shadow-sm sm:rounded-xl sm:p-3">
                      <div class="flex items-center justify-between">
                        <span class="text-[10px] text-gray-400 sm:text-xs">Ganancias</span>
                        <span class="text-[10px] font-bold text-green-500 sm:text-xs">+8%</span>
                      </div>
                      <div class="mt-0.5 text-sm font-bold text-gray-900 sm:mt-1 sm:text-lg">RD$ 450</div>
                    </div>
                    <div class="rounded-lg bg-white p-2 shadow-sm sm:rounded-xl sm:p-3">
                      <div class="flex items-center justify-between">
                        <span class="text-[10px] text-gray-400 sm:text-xs">Productos</span>
                        <span class="text-[10px] text-gray-400 sm:text-xs">1,247</span>
                      </div>
                      <div class="mt-0.5 text-sm font-bold text-gray-900 sm:mt-1 sm:text-lg">2,156</div>
                    </div>
                    <div class="rounded-lg bg-white p-2 shadow-sm sm:rounded-xl sm:p-3">
                      <div class="flex items-center justify-between">
                        <span class="text-[10px] text-gray-400 sm:text-xs">Stock Bajo</span>
                        <span class="text-[10px] font-bold text-red-500 sm:text-xs">23</span>
                      </div>
                      <div class="mt-0.5 text-sm font-bold text-gray-900 sm:mt-1 sm:text-lg">Alertas</div>
                    </div>
                  </div>
                  <!-- Chart -->
                  <div class="mt-3 rounded-lg bg-white p-2 shadow-sm sm:mt-4 sm:rounded-xl sm:p-3">
                    <div class="mb-1.5 text-[10px] font-medium text-gray-500 sm:mb-2 sm:text-xs">Ventas Semanales</div>
                    <div class="flex items-end justify-between gap-0.5 sm:gap-1">
                      <div class="flex flex-1 flex-col items-center gap-0.5 sm:gap-1">
                        <div class="w-full rounded-t bg-gradient-to-t from-primary to-accent" style="height: 40%"><div class="h-full min-h-[3px] rounded-t" /></div>
                      </div>
                      <div class="flex flex-1 flex-col items-center gap-0.5 sm:gap-1">
                        <div class="w-full rounded-t bg-gradient-to-t from-primary to-accent" style="height: 65%"><div class="h-full min-h-[3px] rounded-t" /></div>
                      </div>
                      <div class="flex flex-1 flex-col items-center gap-0.5 sm:gap-1">
                        <div class="w-full rounded-t bg-gradient-to-t from-primary to-accent" style="height: 45%"><div class="h-full min-h-[3px] rounded-t" /></div>
                      </div>
                      <div class="flex flex-1 flex-col items-center gap-0.5 sm:gap-1">
                        <div class="w-full rounded-t bg-gradient-to-t from-primary to-accent" style="height: 80%"><div class="h-full min-h-[3px] rounded-t" /></div>
                      </div>
                      <div class="flex flex-1 flex-col items-center gap-0.5 sm:gap-1">
                        <div class="w-full rounded-t bg-gradient-to-t from-primary to-accent" style="height: 55%"><div class="h-full min-h-[3px] rounded-t" /></div>
                      </div>
                      <div class="flex flex-1 flex-col items-center gap-0.5 sm:gap-1">
                        <div class="w-full rounded-t bg-gradient-to-t from-primary to-accent" style="height: 90%"><div class="h-full min-h-[3px] rounded-t" /></div>
                      </div>
                      <div class="flex flex-1 flex-col items-center gap-0.5 sm:gap-1">
                        <div class="w-full rounded-t bg-gradient-to-t from-primary to-accent" style="height: 70%"><div class="h-full min-h-[3px] rounded-t" /></div>
                      </div>
                    </div>
                    <div class="mt-0.5 flex justify-between sm:mt-1">
                      <span class="text-[8px] text-gray-400 sm:text-[10px]">L</span>
                      <span class="text-[8px] text-gray-400 sm:text-[10px]">M</span>
                      <span class="text-[8px] text-gray-400 sm:text-[10px]">M</span>
                      <span class="text-[8px] text-gray-400 sm:text-[10px]">J</span>
                      <span class="text-[8px] text-gray-400 sm:text-[10px]">V</span>
                      <span class="text-[8px] text-gray-400 sm:text-[10px]">S</span>
                      <span class="text-[8px] text-gray-400 sm:text-[10px]">D</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Home indicator -->
              <div class="flex items-center justify-center pb-2 sm:pb-3">
                <div class="h-0.5 w-8 rounded-full bg-gray-300 sm:h-1 sm:w-10" />
              </div>
            </div>
          </div>
          <!-- Decorative dots -->
          <div class="absolute -left-6 top-16 hidden h-3 w-3 rounded-full bg-primary/20 lg:block sm:h-4 sm:w-4" />
          <div class="absolute -right-3 bottom-8 hidden h-4 w-4 rounded-full bg-accent/20 lg:block sm:h-6 sm:w-6" />
        </div>
      </div>

      <!-- Right: Content -->
      <div class="text-center lg:text-left">
        <span class="badge">FullPOS Owner</span>
        <h2 class="section-title mt-4">Tu Negocio en tu Bolsillo</h2>
        <p class="section-subtitle mt-4 text-left">
          Con FullPOS Owner puedes acceder a la información más importante de tu negocio desde cualquier lugar usando tu teléfono. Ventas en tiempo real, inventario, estadísticas y más.
        </p>

        <div class="mt-6 space-y-3 sm:mt-8 sm:space-y-4">
          <div class="flex items-center gap-3">
            <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 sm:h-8 sm:w-8">
              <svg class="h-3.5 w-3.5 text-primary sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <span class="text-sm text-gray-700 sm:text-base">Ventas del día en tiempo real</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 sm:h-8 sm:w-8">
              <svg class="h-3.5 w-3.5 text-primary sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <span class="text-sm text-gray-700 sm:text-base">Ganancias y márgenes de beneficio</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 sm:h-8 sm:w-8">
              <svg class="h-3.5 w-3.5 text-primary sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <span class="text-sm text-gray-700 sm:text-base">Informes de inventario y stock bajo</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 sm:h-8 sm:w-8">
              <svg class="h-3.5 w-3.5 text-primary sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <span class="text-sm text-gray-700 sm:text-base">Gráficos de ventas por día, semana o mes</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 sm:h-8 sm:w-8">
              <svg class="h-3.5 w-3.5 text-primary sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <span class="text-sm text-gray-700 sm:text-base">Productos más vendidos y estadísticas</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 sm:h-8 sm:w-8">
              <svg class="h-3.5 w-3.5 text-primary sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <span class="text-sm text-gray-700 sm:text-base">Acceso remoto desde cualquier lugar</span>
          </div>
        </div>

        <div class="mt-6 sm:mt-8">
          <a href="#contacto" class="btn-primary px-6 py-3.5 text-sm sm:px-8 sm:py-4 sm:text-base">
            Solicitar Información
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
