---
---

<section id="precios" class="bg-gray-50 py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="text-center">
      <span class="badge">Precios</span>
      <h2 class="section-title mt-4">Precios Transparentes</h2>
      <p class="section-subtitle">
        Un solo plan con todas las funciones incluidas. Sin sorpresas ni cargos ocultos.
      </p>
    </div>

    <div class="mt-10 flex justify-center sm:mt-12">
      <div class="relative w-full max-w-md">
        <!-- Most Popular Badge -->
        <div class="absolute -top-4 left-1/2 z-10 -translate-x-1/2">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-primary px-4 py-1.5 text-xs font-bold text-white shadow-lg sm:px-5">
            <svg class="h-3 w-3 sm:h-3.5 sm:w-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            Más Popular
          </span>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow-xl ring-2 ring-primary sm:p-10">
          <div class="text-center">
            <h3 class="text-xl font-bold text-gray-900 sm:text-2xl">FullPOS</h3>
            <p class="mt-1 text-sm text-gray-500 sm:mt-2">Licencia mensual</p>
            <div class="mt-4 flex items-baseline justify-center gap-1 sm:mt-6">
              <span class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">$20</span>
              <span class="text-base font-medium text-gray-500 sm:text-lg">USD/mes</span>
            </div>
            <p class="mt-1 text-xs text-gray-400 sm:mt-2 sm:text-sm">Compra mínima: 3 meses</p>
          </div>

          <ul class="mt-6 space-y-3 sm:mt-8 sm:space-y-4">
            {[
              'Sistema POS Completo',
              'Productos Ilimitados',
              'Control de Inventario',
              'Reportes y Estadísticas',
              'Informes Móviles (Owner)',
              'Soporte Técnico',
              'Actualizaciones Incluidas',
              'Instalación Local',
              'Demo 5 días Gratis',
            ].map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-green-500 sm:h-5 sm:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-gray-600 sm:text-base">{feature}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6 space-y-3 sm:mt-8">
            <a href="#demo" class="btn-primary w-full justify-center px-8 py-3.5 text-sm sm:py-4 sm:text-base">
              Descargar Demo Gratis
            </a>
            <a href="#contacto" class="btn-secondary w-full justify-center px-8 py-3.5 text-sm sm:py-4 sm:text-base">
              Comprar Licencia
            </a>
          </div>

          <div class="mt-4 rounded-xl bg-gray-50 p-3 sm:mt-6 sm:p-4">
            <div class="flex items-center gap-2 text-xs text-gray-500 sm:text-sm">
              <svg class="h-3.5 w-3.5 text-primary sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span>Descarga la demo, úsala 5 días gratis y solo paga si decides quedarte.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
