---
const plans = [
  {
    id: '3-meses',
    title: '3 Meses',
    total: 'USD $60',
    monthly: '$20 USD por mes',
    badge: null,
    featured: false,
  },
  {
    id: '6-meses',
    title: '6 Meses',
    total: 'USD $120',
    monthly: '$20 USD por mes',
    badge: 'Más Popular',
    featured: true,
  },
  {
    id: '12-meses',
    title: '12 Meses',
    total: 'USD $240',
    monthly: '$20 USD por mes',
    badge: 'Mejor Valor',
    featured: false,
  },
  {
    id: 'personalizado',
    title: 'Personalizado',
    total: 'Contáctanos',
    monthly: 'Tiempo a tu medida',
    badge: null,
    featured: false,
    custom: true,
  },
];

const features = [
  'Sistema FullPOS completo',
  'Todos los módulos incluidos',
  'App FullPOS Owner incluida',
  'Actualizaciones constantes',
  'Soporte técnico',
  'WhatsApp todos los días',
  'Mantenimiento incluido',
  'Sin cargos ocultos',
];
---

<section id="precios" class="bg-gray-50 py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="text-center">
      <span class="badge">Licencias</span>
      <h2 class="section-title mt-4">Elige el tiempo que necesitas</h2>
      <p class="section-subtitle">
        En FullPOS tú eliges por cuánto tiempo quieres tu licencia. La licencia mínima es de 3 meses y puedes adquirir el tiempo que necesites. Cuando tu licencia termine, simplemente la renuevas y continúas trabajando normalmente.
      </p>
    </div>

    <p class="mt-4 text-center text-xs text-gray-400 sm:text-sm">
      Siempre descargarás la versión más reciente de FullPOS.
    </p>

    <!-- License Cards Grid -->
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4 sm:mt-12">
      {plans.map((plan) => (
        <div class={`relative rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 sm:p-8 ${
          plan.featured
            ? 'bg-white shadow-xl ring-2 ring-primary scale-105 sm:scale-110'
            : 'bg-white shadow-md hover:shadow-xl'
        }`}>
          {plan.badge && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class={`inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-bold text-white shadow-lg ${
                plan.badge === 'Más Popular' ? 'bg-primary' : 'bg-gradient-to-r from-primary to-accent'
              }`}>
                <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                {plan.badge}
              </span>
            </div>
          )}

          <div class="text-center">
            <h3 class="text-lg font-bold text-gray-900">{plan.title}</h3>
            <div class="mt-3">
              <span class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">{plan.total}</span>
            </div>
            <p class="mt-1 text-sm text-gray-500">{plan.monthly}</p>
          </div>

          {!plan.custom && (
            <ul class="mt-5 space-y-2.5 border-t border-gray-100 pt-5">
              {features.map((feature) => (
                <li class="flex items-start gap-2.5">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-sm text-gray-600">{feature}</span>
                </li>
              ))}
            </ul>
          )}

          {plan.custom && (
            <div class="mt-5 border-t border-gray-100 pt-5 text-center">
              <p class="text-sm text-gray-500">¿Necesitas un tiempo diferente o una licencia especial?</p>
              <p class="mt-2 text-sm font-semibold text-primary">Escríbenos y te cotizamos.</p>
            </div>
          )}

          <div class="mt-6 space-y-3">
            <a href="#contacto" class={`w-full justify-center text-sm py-3 sm:py-3.5 inline-flex items-center rounded-xl font-semibold transition-all duration-300 ${
              plan.featured
                ? 'bg-primary text-white hover:bg-primary-dark shadow-lg shadow-primary/25'
                : 'border-2 border-gray-200 text-gray-700 hover:border-primary hover:text-primary'
            }`}>
              {plan.custom ? 'Solicitar Cotización' : 'Comprar Licencia'}
            </a>
            {!plan.custom && (
              <button class="download-btn w-full justify-center text-sm py-3 sm:py-3.5 inline-flex items-center rounded-xl font-semibold transition-all duration-300 border-2 border-primary/30 text-primary hover:bg-primary hover:text-white hover:border-primary" data-original-text="Descargar Demo Gratis">
                <svg class="download-icon mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                <span class="download-text">Descargar Demo Gratis</span>
              </button>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Payment Methods Section -->
    <div class="mt-12 rounded-2xl bg-white p-6 shadow-md sm:mt-16 sm:p-10">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
          Métodos de Pago
        </div>
        <h3 class="mt-4 text-xl font-bold text-gray-900 sm:text-2xl">Paga como prefieras</h3>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-3 sm:mt-8">
        <div class="flex items-center gap-3 rounded-xl bg-gray-50 p-4">
          <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-gray-900">Tarjeta de Crédito</div>
            <div class="text-xs text-gray-500">Visa, MasterCard, American Express</div>
          </div>
        </div>
        <div class="flex items-center gap-3 rounded-xl bg-gray-50 p-4">
          <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-gray-900">Tarjeta de Débito</div>
            <div class="text-xs text-gray-500">Débito directo</div>
          </div>
        </div>
        <div class="flex items-center gap-3 rounded-xl bg-gray-50 p-4">
          <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-green-500/10 text-green-500">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-gray-900">Transferencia Bancaria</div>
            <div class="text-xs text-gray-500">República Dominicana</div>
          </div>
        </div>
      </div>

      <div class="mt-6 rounded-xl bg-gradient-to-r from-primary/5 to-accent/5 p-4 text-center sm:p-6">
        <div class="flex items-center justify-center gap-2 text-sm text-gray-600">
          <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>Cuando finalice el periodo de prueba de 5 días, puedes comprar tu licencia y el sistema se activa al instante después del pago.</span>
        </div>
      </div>
    </div>
  </div>
</section>
