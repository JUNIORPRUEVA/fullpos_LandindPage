---
const modules = [
  {
    title: 'Ventas',
    desc: 'Procesa ventas de forma rápida con catálogo de productos, múltiples formas de pago y facturación electrónica.',
    icon: 'cart',
  },
  {
    title: 'Inventario',
    desc: 'Controla tu inventario en tiempo real con movimientos automatizados, alertas de stock bajo y ajustes.',
    icon: 'inventory',
  },
  {
    title: 'Compras',
    desc: 'Administra compras a proveedores con órdenes de compra y control de costos.',
    icon: 'purchase',
  },
  {
    title: 'Clientes',
    desc: 'Registra clientes con historial de compras, créditos y datos de contacto.',
    icon: 'users',
  },
  {
    title: 'Cotizaciones',
    desc: 'Crea cotizaciones profesionales y conviértelas en ventas con un clic.',
    icon: 'document',
  },
  {
    title: 'Gastos',
    desc: 'Registra y categoriza gastos para tener control financiero completo.',
    icon: 'expense',
  },
  {
    title: 'Reportes',
    desc: 'Reportes detallados de ventas, ganancias, productos y rendimiento del negocio.',
    icon: 'chart',
  },
  {
    title: 'Usuarios',
    desc: 'Múltiples usuarios con permisos y roles personalizables para tu equipo.',
    icon: 'team',
  },
  {
    title: 'Impresoras',
    desc: 'Compatible con impresoras térmicas ESC/POS y matriciales para tickets y facturas.',
    icon: 'printer',
  },
  {
    title: 'Código de Barras',
    desc: 'Soporte para lectores de código de barras USB. Busca productos al instante.',
    icon: 'barcode',
  },
  {
    title: 'Configuración',
    desc: 'Personaliza el sistema según las necesidades específicas de tu negocio.',
    icon: 'settings',
  },
  {
    title: 'Cajas',
    desc: 'Control de apertura y cierre de caja con ingresos, egresos y arqueo.',
    icon: 'cash',
  },
];
---

<section id="modulos" class="bg-dark py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="text-center">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary/90">Módulos</span>
      <h2 class="section-title mt-4 text-white">Módulos Completos</h2>
      <p class="section-subtitle text-gray-400">
        FullPOS incluye todos los módulos que necesitas para administrar cada aspecto de tu negocio. Sin limitaciones, sin módulos adicionales que comprar.
      </p>
    </div>

    <div class="mt-8 grid gap-4 sm:mt-12 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3 lg:gap-8">
      {modules.map((m) => (
        <div class="group relative overflow-hidden rounded-2xl border border-white/5 bg-dark-3/80 p-5 transition-all duration-500 hover:-translate-y-1 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 sm:p-6">
          <!-- Glow effect on hover -->
          <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-primary/0 via-primary/5 to-accent/0 opacity-0 blur-xl transition-opacity duration-500 group-hover:opacity-100" />
          
          <div class="relative">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-white group-hover:shadow-lg group-hover:shadow-primary/25 sm:h-12 sm:w-12">
              {m.icon === 'cart' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" /></svg>
              )}
              {m.icon === 'inventory' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
              )}
              {m.icon === 'purchase' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
              )}
              {m.icon === 'users' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
              )}
              {m.icon === 'document' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              )}
              {m.icon === 'expense' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              )}
              {m.icon === 'chart' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
              )}
              {m.icon === 'team' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              )}
              {m.icon === 'printer' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
              )}
              {m.icon === 'barcode' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
              )}
              {m.icon === 'settings' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /></svg>
              )}
              {m.icon === 'cash' && (
                <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              )}
            </div>
            <h3 class="mt-3 text-base font-bold text-white sm:mt-4 sm:text-lg">{m.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-gray-400 sm:mt-2">{m.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
