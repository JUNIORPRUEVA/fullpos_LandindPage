---
const businessTypes = [
  {
    name: 'Tiendas',
    desc: 'Controla ventas, inventario y caja de pequeños y medianos puntos de venta.',
  },
  {
    name: 'Minimarkets',
    desc: 'Administra productos, stock y clientes con rapidez en ventas diarias.',
  },
  {
    name: 'Ferreterías',
    desc: 'Gestiona materiales, herramientas, precios y control de inventario.',
  },
  {
    name: 'Almacenes',
    desc: 'Organiza productos en stock, entradas, salidas y reportes de existencia.',
  },
  {
    name: 'Negocios comerciales',
    desc: 'Cubre las necesidades de comercios con ventas, caja y seguimiento de clientes.',
  },
  {
    name: 'Pequeñas y medianas empresas',
    desc: 'Brinda control de operaciones y reportes para la gestión diaria del negocio.',
  },
];
---

<section class="bg-gray-50 py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="text-center">
      <span class="badge">Negocios</span>
      <h2 class="section-title mt-4">¿Para qué tipo de negocios funciona?</h2>
      <p class="section-subtitle">
        FullPOS está diseñado para tiendas, minimarkets, ferreterías, almacenes y otras empresas comerciales.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {businessTypes.map((item) => (
        <div class="rounded-3xl border border-gray-200/80 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <h3 class="text-lg font-semibold text-slate-900">{item.name}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
