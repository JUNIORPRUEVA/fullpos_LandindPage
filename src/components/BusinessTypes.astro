---
const businesses = [
  { name: 'Ferreterías', icon: 'tool', desc: 'Controla inventario de materiales de construcción, herramientas y más.' },
  { name: 'Supermercados', icon: 'shopping-bag', desc: 'Gestiona miles de productos con códigos de barras y categorías.' },
  { name: 'Colmados', icon: 'home', desc: 'Administra ventas rápidas y controla el crédito a clientes.' },
  { name: 'Farmacias', icon: 'heart', desc: 'Controla medicamentos con lotes, fechas de vencimiento y precios.' },
  { name: 'Tiendas', icon: 'gift', desc: 'Gestiona inventario de ropa, calzado, accesorios y más.' },
  { name: 'Repuestos', icon: 'settings', desc: 'Administra catálogos de repuestos con referencias y compatibilidades.' },
  { name: 'Electrónica', icon: 'monitor', desc: 'Controla productos tecnológicos con números de serie y garantías.' },
  { name: 'Negocios Pequeños', icon: 'briefcase', desc: 'La solución perfecta para pequeños y medianos comercios.' },
];
---

<section class="bg-gray-50 py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="text-center">
      <span class="badge">Negocios</span>
      <h2 class="section-title mt-4">¿Para Quién es FullPOS?</h2>
      <p class="section-subtitle">
        FullPOS está diseñado para una amplia variedad de negocios. Si vendes productos, FullPOS es para ti.
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {businesses.map((biz) => (
        <div class="group flex items-center gap-4 rounded-2xl bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              {biz.icon === 'tool' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />}
              {biz.icon === 'shopping-bag' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />}
              {biz.icon === 'home' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />}
              {biz.icon === 'heart' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />}
              {biz.icon === 'gift' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />}
              {biz.icon === 'settings' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />}
              {biz.icon === 'monitor' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />}
              {biz.icon === 'briefcase' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />}
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">{biz.name}</h3>
            <p class="text-sm text-gray-500">{biz.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
