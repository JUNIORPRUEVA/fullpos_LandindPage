---
const testimonials = [
  {
    name: 'Carlos Méndez',
    business: 'Ferretería El Constructor',
    content: 'FullPOS transformó la forma en que manejamos nuestro inventario. Ahora sabemos exactamente qué productos tenemos y cuáles necesitamos pedir. La función de reportes móviles me permite ver las ventas desde mi casa.',
    color: 'bg-primary',
  },
  {
    name: 'María Rodríguez',
    business: 'Supermercado Doña María',
    content: 'Llevaba años buscando un sistema POS que funcionara sin internet. FullPOS es justo lo que necesitábamos. Mis empleados aprendieron a usarlo en un día. El soporte técnico fue excelente.',
    color: 'bg-accent',
  },
  {
    name: 'Roberto Jiménez',
    business: 'Tienda El Mayorista',
    content: 'Desde que implementamos FullPOS, nuestras ventas aumentaron un 30%. El control de inventario nos ayudó a reducir pérdidas y los reportes nos dan una visión clara del negocio. Muy recomendado.',
    color: 'bg-green-500',
  },
];
---

<section class="py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="text-center">
      <span class="badge">Testimonios</span>
      <h2 class="section-title mt-4">Lo que Dicen Nuestros Clientes</h2>
      <p class="section-subtitle">
        Negocios como el tuyo ya confían en FullPOS para administrar sus operaciones diarias.
      </p>
    </div>

    <div class="mt-8 grid gap-4 sm:mt-12 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="card card-hover relative">
          <svg class="absolute right-4 top-4 h-8 w-8 text-gray-100 sm:right-6 sm:top-6 sm:h-12 sm:w-12" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" /></svg>

          <div class="flex gap-0.5 sm:gap-1">
            <svg class="h-4 w-4 text-yellow-400 sm:h-5 sm:w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="h-4 w-4 text-yellow-400 sm:h-5 sm:w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="h-4 w-4 text-yellow-400 sm:h-5 sm:w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="h-4 w-4 text-yellow-400 sm:h-5 sm:w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="h-4 w-4 text-yellow-400 sm:h-5 sm:w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          </div>

          <p class="mt-3 text-sm leading-relaxed text-gray-600 sm:mt-4 sm:text-base">"{t.content}"</p>

          <div class="mt-4 flex items-center gap-3 border-t border-gray-100 pt-4 sm:mt-6 sm:pt-6">
            <div class={"flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full " + t.color + " text-sm font-bold text-white sm:h-10 sm:w-10"}>
              {t.name.charAt(0)}
            </div>
            <div>
              <div class="text-sm font-bold text-gray-900 sm:text-base">{t.name}</div>
              <div class="text-xs text-gray-500 sm:text-sm">{t.business}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
