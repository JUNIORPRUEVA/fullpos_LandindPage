---
const testimonials = [
  {
    name: 'Carlos Méndez',
    business: 'Ferretería El Constructor',
    content: 'FullPOS transformó la forma en que manejamos nuestro inventario. Ahora tenemos control total sobre nuestras ventas y podemos ver reportes desde el celular.',
    gradient: 'from-blue-600 to-blue-400',
  },
  {
    name: 'María Rodríguez',
    business: 'Supermercado Doña María',
    content: 'La facilidad de uso de FullPOS es increíble. En un día estábamos vendiendo. El soporte técnico es excelente y siempre están disponibles.',
    gradient: 'from-purple-600 to-pink-500',
  },
  {
    name: 'Roberto Jiménez',
    business: 'Tienda El Mayorista',
    content: 'Tener FullPOS en mi negocio fue la mejor decisión. Funciona sin internet, lo que es crucial para nosotros. Los reportes desde el celular me dan tranquilidad.',
    gradient: 'from-emerald-500 to-teal-400',
  },
];
---

<section class="bg-white py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="text-center">
      <span class="badge">Testimonios</span>
      <h2 class="section-title mt-4">Lo que dicen nuestros clientes</h2>
      <p class="section-subtitle">
        La satisfacción de nuestros clientes habla por sí sola.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:mt-12 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {testimonials.map((t) => (
        <div class="card card-hover group relative">
          <div class="mb-6 text-primary/20">
            <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" /></svg>
          </div>
          <p class="text-sm leading-relaxed text-gray-600 sm:text-base">"{t.content}"</p>
          <div class="mt-6 flex items-center gap-3">
            <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-br ${t.gradient} text-sm font-bold text-white`}>
              {t.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900">{t.name}</p>
              <p class="text-xs text-gray-500">{t.business}</p>
            </div>
          </div>
          <div class="mt-3 flex gap-0.5">
            {[...Array(5)].map((_, i) => (
              <svg key={i} class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
