---
const reasons = [
  {
    title: 'Funciona sin Internet',
    desc: 'Continúa vendiendo aunque falle tu conexión. FullPOS funciona completamente offline.',
    gradient: 'from-blue-500 to-cyan-500',
    icon: 'wifi',
  },
  {
    title: 'Reportes desde tu Celular',
    desc: 'Accede a ventas, inventario y estadísticas desde cualquier lugar con FullPOS Owner.',
    gradient: 'from-orange-500 to-pink-500',
    icon: 'phone',
  },
  {
    title: 'Fácil de Usar',
    desc: 'Interfaz intuitiva diseñada para que aprendas a usarlo en minutos, no en horas.',
    gradient: 'from-green-500 to-emerald-500',
    icon: 'smile',
  },
  {
    title: 'Soporte Técnico',
    desc: 'Te acompañamos en cada paso con instalación profesional y soporte continuo.',
    gradient: 'from-purple-500 to-indigo-500',
    icon: 'support',
  },
];
---

<section id="que-es-fullpos" class="bg-white py-16 sm:py-20 lg:py-28">
  <div class="container-custom">
    <div class="text-center">
      <span class="badge">Qué es FullPOS</span>
      <h2 class="section-title mt-4">Qué es FullPOS</h2>
      <p class="section-subtitle">
        FullPOS es un sistema de punto de venta diseñado para negocios que necesitan registrar ventas, manejar productos, controlar inventario, abrir y cerrar caja, administrar clientes y consultar reportes de forma sencilla.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:mt-12 sm:grid-cols-2 sm:gap-8">
      {reasons.map((r) => (
        <div class="group relative overflow-hidden rounded-2xl bg-white p-6 shadow-md transition-all duration-300 hover:-translate-y-2 hover:shadow-xl sm:p-8">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/0 via-primary/[0.02] to-accent/[0.02] opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
          <div class="relative">
            <div class={`inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br ${r.gradient} shadow-lg transition-transform duration-300 group-hover:scale-110 sm:h-16 sm:w-16`}>
              {r.icon === 'wifi' && (
                <svg class="h-7 w-7 text-white sm:h-8 sm:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.858 15.355-5.858 21.213 0" /></svg>
              )}
              {r.icon === 'phone' && (
                <svg class="h-7 w-7 text-white sm:h-8 sm:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
              )}
              {r.icon === 'smile' && (
                <svg class="h-7 w-7 text-white sm:h-8 sm:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              )}
              {r.icon === 'support' && (
                <svg class="h-7 w-7 text-white sm:h-8 sm:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
              )}
            </div>
            <h3 class="mt-4 text-lg font-bold text-gray-900 transition-colors duration-300 group-hover:text-primary sm:text-xl">{r.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-500 sm:text-base">{r.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
